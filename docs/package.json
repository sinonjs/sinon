{
  "name": "sinon-docs",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "test:docs": "tap 'tests/**/*.test.js' --disable-coverage",
    "docs:generate-sidebar": "node scripts/generate-sidebar.mjs",
    "docs:prebuild": "node scripts/generate-sidebar.mjs",
    "predocs:build": "npm run docs:prebuild",
    "docs:dev": "vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "docs:serve": "vitepress preview . --port 4173",
    "docs:link-check": "./scripts/link-check.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "tap": "^21.5.1",
    "vitepress": "^2.0.0-alpha.17",
    "vitepress-plugin-llms": "^1.12.1",
    "vue": "^3.5.30"
  },
  "dependencies": {
    "sinon": "file:.."
  }
}
